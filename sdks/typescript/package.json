    "@opentelemetry/semantic-conventions": "^1.30.0"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/beater/beater"
  }
