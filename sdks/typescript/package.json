{
  "name": "@beater/sdk",
  "version": "0.1.0",
  "description": "Ergonomic agent observability SDK for Beater (OpenTelemetry-native)",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "dist/index.js",
